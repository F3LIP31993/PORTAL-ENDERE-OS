# Portal de Endereços - exemplo de configuração para produção
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5000
PORTAL_SECRET_KEY=troque-esta-chave
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None
CORS_ALLOWED_ORIGINS=https://f3lip31993.github.io,http://localhost:5000

# PostgreSQL recomendado em produção
# DATABASE_URL=postgresql://usuario:senha@host:5432/portal_enderecos

# Opcional - SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@portal.local
ADMIN_EMAIL=
